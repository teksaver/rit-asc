{
  "name": "RouteIn Dev",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "RouteIn (Vite)",
      "onAutoForward": "openBrowser"
    }
  },
  "overrideCommand": false,
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": ["oxc.oxc-vscode", "vitest.explorer"]
    }
  }
}
